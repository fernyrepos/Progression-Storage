	<!-- Filters -->

	<!-- Crate: Root minus Foods, FoodMeals, Corpses, Chunks -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="sbz_MidCrate"]</xpath>
		<value>
			<building>
				<fixedStorageSettings>
					<filter>
						<disallowNotEverStorable>true</disallowNotEverStorable>
						<categories Inherit="False">
							<li>Root</li>
						</categories>
						<disallowedCategories Inherit="False">
							<li>Foods</li>
							<li>FoodMeals</li>
							<li>Corpses</li>
							<li>Chunks</li>
						</disallowedCategories>
					</filter>
				</fixedStorageSettings>
			</building>
		</value>
	</Operation>

