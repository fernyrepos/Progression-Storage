<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Pallets: set research to ReelIndustrialStorage -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="sbz_MiniPallet"]</xpath>
		<value>
			<researchPrerequisites Inherit="false">
				<li>ReelIndustrialStorage</li>
			</researchPrerequisites>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="sbz_HalfPallet"]</xpath>
		<value>
			<researchPrerequisites Inherit="false">
				<li>ReelIndustrialStorage</li>
			</researchPrerequisites>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="sbz_Pallet"]</xpath>
		<value>
			<researchPrerequisites Inherit="false">
				<li>ReelIndustrialStorage</li>
			</researchPrerequisites>
		</value>
	</Operation>

